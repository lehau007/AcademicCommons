# Copy this file to .env and fill in the secrets before running `make up`.
# Values shown here are safe defaults for local development only.

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=academic_kb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Redis (arq queue)
REDIS_URL=redis://redis:6379/0

# Storage (MinIO local / R2 cloud)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=documents
STORAGE_PUBLIC_HOST=http://localhost:9000

# Auth
JWT_SECRET=changeme_in_prod_minimum_32_bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_HOURS=24
JWT_REFRESH_TTL_DAYS=7

# LLM — Bedrock primary. Configure long-term Bedrock API key (OpenAI-compatible endpoint).
BEDROCK_API_KEY=
BEDROCK_BASE_URL=          # optional, defaults to https://bedrock-mantle.{AWS_REGION}.api.aws/v1
AWS_REGION=us-east-1
AWS_PROFILE=               # optional fallback SSO profile if BEDROCK_API_KEY is not set
BEDROCK_MODEL_ID=moonshotai.kimi-k2.5

# LLM — Optional Azure fallback / compatibility with older experiment naming.
AZURE_AI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://haulv226038-3382-resource.services.ai.azure.com/openai/v1
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_INPUT_COST_PER_1M=0
AZURE_OPENAI_OUTPUT_COST_PER_1M=0

# LLM — Fallbacks after Bedrock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_PROVIDER_ORDER=bedrock,gemini,groq

# Optional eval_optimizer SDK layer. Disabled by default; set enabled flows
# to a comma-separated list like "mindmap,mock_test" for gradual rollout.
# Keep SDK provider fallback disabled: LLMRouter owns provider failover.
LLM_OPTIMIZER_ENABLED=false
LLM_OPTIMIZER_ENABLED_FLOWS=
LLM_OPTIMIZER_PROVIDER_FALLBACK_ENABLED=false
LLM_OPTIMIZER_PREFIX_CACHE_ENABLED=false
LLM_OPTIMIZER_SEMANTIC_CACHE_ENABLED=false
LLM_OPTIMIZER_CASCADE_ROUTING_ENABLED=false
LLM_OPTIMIZER_SHADOW_ENABLED=false
LLM_OPTIMIZER_BUDGET_CAP_USD=
LLM_OPTIMIZER_ON_BUDGET_EXCEEDED=warn
# Cost reporting: JSONL log of every optimizer call (read via `python -m app.cli optimizer-report`)
LLM_OPTIMIZER_LOGGING_ENABLED=true
LLM_OPTIMIZER_LOG_PATH=data/pipeline_outputs/optimizer_logs/optimizer.jsonl
# Prices for models missing from the SDK default table, JSON {"provider:model_id":[in_per_mtok,out_per_mtok]}
LLM_OPTIMIZER_PRICE_TABLE_JSON={"gemini:gemini-3.1-flash-lite":[0.10,0.40],"groq:meta-llama/llama-4-scout-17b-16e-instruct":[0.11,0.34]}
LLM_OPTIMIZER_PROMPT_VERSION=academic-kb-v1
LLM_OPTIMIZER_MODEL_VERSION=default
LLM_OPTIMIZER_PROFILE_DEFAULT=default
LLM_OPTIMIZER_PROFILE_TUTOR=rag_answering
LLM_OPTIMIZER_PROFILE_MINDMAP=concept_graph
LLM_OPTIMIZER_PROFILE_MOCK_TEST=question_generation
LLM_OPTIMIZER_PROFILE_TOPIC_TAGS=topic_tagging

# Agent 2 search
TAVILY_API_KEY=
AGENT2_ENABLED=true
AGENT2_TIMEOUT_SECONDS=15

# Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Worker concurrency
WORKER_OCR_CONCURRENCY=1
WORKER_OCR_JOB_TIMEOUT_SECONDS=1800
WORKER_EVAL_CONCURRENCY=4
WORKER_INDEX_CONCURRENCY=4

# Retrieval
TUTOR_MMR_K=8
TUTOR_MMR_LAMBDA=0.7
TUTOR_TIER_BOOST=1.15
