POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=academic_kb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

REDIS_URL=redis://redis:6379/0

# Error file logging. On by default so failures are captured to a rotating file
# (no need to exec into the container). Set false in production to keep stdout-only
# and avoid filling the server disk.
ERROR_LOG_FILE_ENABLED=true
ERROR_LOG_FILE_PATH=logs/backend-errors.log

# Email verification. `console` backend logs the verification link to stdout
# (read via `docker logs -f api`); use it for local dev/tests. Set `resend` once
# RESEND_API_KEY is configured. The From address must use a Resend-verified domain.
EMAIL_BACKEND=console
RESEND_API_KEY=
RESEND_FROM=Academic Commons <onboarding@resend.dev>
APP_BASE_URL=http://localhost:3000
EMAIL_VERIFICATION_TTL_MINUTES=60
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=documents
STORAGE_PUBLIC_HOST=http://localhost:9000

JWT_SECRET=changeme_in_prod_minimum_32_bytes
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_HOURS=24
JWT_REFRESH_TTL_DAYS=7

# Comma-separated list of browser origins allowed by CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Per-IP rate limits. RATE_LIMIT_BACKEND=memory (single instance) or redis
# (shared state across instances behind a load balancer).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_LOGIN_PER_MINUTE=10

AZURE_AI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.services.ai.azure.com
AZURE_OPENAI_DEPLOYMENT=<deployment-name>
AZURE_OPENAI_API_VERSION=2024-02-01

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b

# OpenCode (opencode.ai) Go-plan subscription — OpenAI-compatible, restricted model
# catalog (MiniMax/Kimi/GLM/DeepSeek/Qwen/MiMo/Hy families, no Claude/GPT/Gemini).
OPENCODE_API_KEY=
OPENCODE_MODEL=minimax-m3
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# OpenRouter (openrouter.ai) — OpenAI-compatible gateway aggregating hundreds of
# models. gpt-5.4-mini picked from a mid-priced comparison (tests/openrouter_api_doc.md)
# for speed + accurate OCR/vision transcription of lecture slides.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.4-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter top-tier embedding & rerank (selected at startup by key presence
# via build_embedding_service: OpenRouter -> NVIDIA -> offline stub).
# embedding: openai/text-embedding-3-small returns 1536-dim vectors -> EMBEDDING_DIM must be 1536.
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# rerank: Cohere-style /rerank endpoint, returns [{index, relevance_score}].
OPENROUTER_RERANK_MODEL=cohere/rerank-v3.5

# AWS Bedrock (Amazon Nova) — uses long-term API key (OpenAI-compatible endpoint)
# NOTE: do not put inline `# ...` comments after a value — docker-compose's
# env_file parser keeps them as part of the value. Keep comments on their own line.
BEDROCK_API_KEY=
# optional, defaults to https://bedrock-mantle.{AWS_REGION}.api.aws/v1
BEDROCK_BASE_URL=
AWS_REGION=us-east-1
# optional fallback SSO profile if BEDROCK_API_KEY is not set
AWS_PROFILE=
# e.g. moonshotai.kimi-k2.5 (only model with vision support on current account)
BEDROCK_MODEL_ID=moonshotai.kimi-k2.5

# Provider failover order; missing-credential providers are skipped.
LLM_PROVIDER_ORDER=bedrock,gemini,groq

# Optional eval_optimizer SDK layer. Disabled by default; set enabled flows
# to a comma-separated list like "mindmap,mock_test" for gradual rollout.
# Keep SDK provider fallback disabled: LLMRouter owns provider failover.
LLM_OPTIMIZER_ENABLED=false
LLM_OPTIMIZER_ENABLED_FLOWS=
LLM_OPTIMIZER_PROVIDER_FALLBACK_ENABLED=false
LLM_OPTIMIZER_PREFIX_CACHE_ENABLED=false
LLM_OPTIMIZER_SEMANTIC_CACHE_ENABLED=false
LLM_OPTIMIZER_CASCADE_ROUTING_ENABLED=false
LLM_OPTIMIZER_SHADOW_ENABLED=false
LLM_OPTIMIZER_BUDGET_CAP_USD=
LLM_OPTIMIZER_ON_BUDGET_EXCEEDED=warn
# Cost reporting: JSONL log of every optimizer call (read via `python -m app.cli optimizer-report`)
LLM_OPTIMIZER_LOGGING_ENABLED=true
LLM_OPTIMIZER_LOG_PATH=data/pipeline_outputs/optimizer_logs/optimizer.jsonl
# Prices for models missing from the SDK default table, JSON {"provider:model_id":[in_per_mtok,out_per_mtok]}
LLM_OPTIMIZER_PRICE_TABLE_JSON={"gemini:gemini-3.1-flash-lite":[0.10,0.40],"groq:meta-llama/llama-4-scout-17b-16e-instruct":[0.11,0.34]}
LLM_OPTIMIZER_PROMPT_VERSION=academic-kb-v1
LLM_OPTIMIZER_MODEL_VERSION=default
LLM_OPTIMIZER_PROFILE_DEFAULT=default
LLM_OPTIMIZER_PROFILE_TUTOR=rag_answering
LLM_OPTIMIZER_PROFILE_MINDMAP=concept_graph
LLM_OPTIMIZER_PROFILE_MOCK_TEST=question_generation
LLM_OPTIMIZER_PROFILE_TOPIC_TAGS=topic_tagging

OCR_ENABLE_REAL_VISION=true
# Concurrent VLM calls per document during OCR extraction (default: 6)
OCR_VISION_MAX_WORKERS=6

# NVIDIA NIM hosted embeddings + reranking. Without NVIDIA_API_KEY the backend
# falls back to the offline deterministic embedder and local cosine ordering.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_DIM=1536
RERANK_MODEL=nvidia/llama-nemotron-rerank-vl-1b-v2
RERANK_ENABLED=true
# Reranking is hosted on a different base than embeddings: {NVIDIA_RERANK_BASE}/{RERANK_MODEL}/reranking
NVIDIA_RERANK_BASE=https://ai.api.nvidia.com/v1/retrieval

WORKER_OCR_CONCURRENCY=1
WORKER_OCR_JOB_TIMEOUT_SECONDS=1800
WORKER_EVAL_CONCURRENCY=4
WORKER_INDEX_CONCURRENCY=4

TAVILY_API_KEY=
AGENT2_ENABLED=true
AGENT2_TIMEOUT_SECONDS=15

# Chunks kept after MMR/rerank and sent to the answer step (precision@k: lower = less noise).
TUTOR_MMR_K=6
TUTOR_MMR_LAMBDA=0.7
TUTOR_TIER_BOOST=1.15
# Pre-rerank cosine floor. 0.0 = disabled. Coarse (cosine can't separate adjacent
# subtopics); the rerank floor below is the discriminative one.
TUTOR_SIM_THRESHOLD=0.0
# Post-rerank relevance floor (cohere score ~0.0–1.0) → dynamic k: chunks below this are
# dropped so out-of-scope questions return few/no chunks. 0.0 = disabled. Start ~0.2–0.4.
TUTOR_RERANK_THRESHOLD=0.0
